# .env.example
VITE_GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=
VITE_OPENWEATHER_API_KEY=

# Firebase Web config overrides for Vite/AI Studio previews.
# Leave blank to use firebase-applet-config.json.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_ID=

# SendGrid Integrations
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=

# Twilio Integrations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe Deposit Checkout
STRIPE_SECRET_KEY=
PUBLIC_APP_URL=
STRIPE_WEBHOOK_SECRET=

# Firebase Admin for server-side Stripe webhook updates
FIREBASE_PROJECT_ID=
FIRESTORE_DATABASE_ID=
# Use one of:
# FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=
