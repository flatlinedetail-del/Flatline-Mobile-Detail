{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user (Admin or Technician)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "technician"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Potential customer or job",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "follow_up", "quoted", "waiting", "booked", "lost", "no_answer"] },
        "vehicleInfo": { "type": "string" },
        "requestedService": { "type": "string" },
        "quotedPrice": { "type": "number" },
        "notes": { "type": "string" },
        "followUpDate": { "type": "string" },
        "leadSource": { "type": "string" },
        "priority": { "type": "string", "enum": ["hot", "warm", "cold"] },
        "routeArea": { "type": "string" },
        "lastContactDate": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "Retail client",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "loyaltyPoints": { "type": "number" },
        "isVIP": { "type": "boolean" },
        "vipSettings": { "type": "object" },
        "notes": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" }
      }
    },
    "Vendor": {
      "title": "Vendor",
      "description": "Business account (Collision center, Dealership, etc.)",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "contactName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string", "enum": ["collision_center", "dealership", "fleet"] },
        "billingTerms": { "type": "string" },
        "pricingProfileId": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled detailing job",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "vendorId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "serviceIds": { "type": "array", "items": { "type": "string" } },
        "addOnIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["scheduled", "confirmed", "en_route", "in_progress", "completed", "paid", "canceled", "no_show"] },
        "scheduledAt": { "type": "string" },
        "address": { "type": "string" },
        "totalAmount": { "type": "number" },
        "technicianId": { "type": "string" },
        "commissionAmount": { "type": "number" },
        "notes": { "type": "string" },
        "vin": { "type": "string" },
        "roNumber": { "type": "string" },
        "recurringInfo": { "type": "object" }
      }
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "technicianId": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "linkedAppointmentId": { "type": "string" }
      }
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Customer or vendor vehicle",
      "type": "object",
      "properties": {
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "color": { "type": "string" },
        "vin": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerType": { "type": "string", "enum": ["customer", "vendor"] }
      }
    },
    "Service": {
      "title": "Service",
      "description": "Detailing service catalog item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "basePrice": { "type": "number" },
        "pricingBySize": { "type": "object" },
        "isTaxable": { "type": "boolean" },
        "estimatedDuration": { "type": "number" },
        "requiresWaiver": { "type": "boolean" },
        "isActive": { "type": "boolean" }
      }
    },
    "AddOn": {
      "title": "AddOn",
      "description": "Service add-on item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "isTaxable": { "type": "boolean" },
        "estimatedDuration": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    },
    "Setting": {
      "title": "Setting",
      "description": "Business settings",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "taxRate": { "type": "number" },
        "currency": { "type": "string" },
        "timezone": { "type": "string" },
        "commissionRate": { "type": "number" },
        "commissionType": { "type": "string" },
        "baseAddress": { "type": "string" },
        "baseLatitude": { "type": "number" },
        "baseLongitude": { "type": "number" },
        "travelPricing": { "type": "object" },
        "loyaltySettings": { "type": "object" },
        "technicianOverrides": { "type": "object" }
      }
    },
    "Category": {
      "title": "Category",
      "description": "Custom category for services, add-ons, expenses, or inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["service", "addon", "expense", "inventory"] },
        "isActive": { "type": "boolean" },
        "sortOrder": { "type": "number" }
      },
      "required": ["name", "type"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/leads/{leadId}": { "schema": "Lead", "description": "Leads" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Retail customers" },
    "/vendors/{vendorId}": { "schema": "Vendor", "description": "Vendor accounts" },
    "/appointments/{appointmentId}": { "schema": "Appointment", "description": "Appointments" },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "Business expenses" },
    "/vehicles/{vehicleId}": { "schema": "Vehicle", "description": "Vehicles" },
    "/services/{serviceId}": { "schema": "Service", "description": "Service catalog" },
    "/addons/{addOnId}": { "schema": "AddOn", "description": "Add-ons catalog" },
    "/settings/{settingId}": { "schema": "Setting", "description": "Business settings" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Custom categories" }
  }
}
